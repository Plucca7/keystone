{
  "name": "lzr-keystone",
  "version": "0.1.0",
  "description": "Start a project that is born to professional standards — without building the foundation by hand.",
  "type": "module",
  "bin": {
    "keystone": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "templates/web",
    "templates/api",
    "templates/agent-harness",
    "docs",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "!templates/*/node_modules",
    "!templates/*/.next",
    "!templates/*/.turbo",
    "!templates/*/dist",
    "!templates/*/coverage",
    "!templates/*/test-results",
    "!templates/*/playwright-report",
    "!templates/**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepack": "npm run build"
  },
  "keywords": [
    "scaffold",
    "project-generator",
    "boilerplate",
    "starter"
  ],
  "author": "Paulo de Lucca",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LZR-Technologies/keystone.git"
  },
  "bugs": {
    "url": "https://github.com/LZR-Technologies/keystone/issues"
  },
  "homepage": "https://github.com/LZR-Technologies/keystone#readme",
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "eslint-plugin-import": "^2.30.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
