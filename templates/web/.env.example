# Local development environment. Copy to .env.local (gitignored) and fill in
# real values -- only variables actually read by this template's code or
# scripts are listed here. Do not add a provider's placeholder vars until the
# code reads them: an unread var is drift that misleads the next developer
# into thinking a feature is wired up when it is not.

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Database ===
# Required by scripts/db-migrate.sh (fails fast without it) and by the
# integration test layer (src/__tests__/integration/), which skips cleanly
# when this is unset. Point it at a disposable local PostgreSQL -- never a
# shared or production database.
DATABASE_URL=postgres://user:pass@localhost:5432/app_dev

# === Deploy pipeline (CI only -- not read by this app locally) ===
# HEALTH_URL and APP_URL are GitHub Environment variables consumed by
# .github/workflows/deploy-staging.yml and deploy-production.yml (smoke
# check and the environment's UI link, respectively). They are listed here
# only as documentation of what each deploy environment must configure --
# see docs/deploy.md. Setting them in .env.local has no effect locally.
# HEALTH_URL=https://staging.example.com/api/v1/health
# APP_URL=https://staging.example.com
