{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git config user.name)",
      "Bash(git config user.name:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(date:*)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)"
    ],
    "deny": ["Read(.env)", "Read(.env.*)", "Read(**/secrets/**)", "Bash(rm -rf:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/block-secret.mjs" },
          { "type": "command", "command": "node .claude/hooks/block-protected-branch.mjs" }
        ]
      }
    ]
  }
}
