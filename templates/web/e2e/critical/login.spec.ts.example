import { test, expect } from '@playwright/test'

/**
 * Critical login — verifies that the session created by globalSetup works.
 *
 * If this fails, all other critical specs will fail too (because the storage
 * state is invalid). It serves as a guard to catch the problem early in the
 * CI report.
 *
 * ─────────────────────────────────────────────────────────────────────────
 * HOW TO ADAPT:
 *
 * 1. Rename: login.spec.ts.example → login.spec.ts
 * 2. Adjust the authenticated routes for your app (/dashboard, /app, /home...)
 * 3. Make sure e2e/fixtures/global-setup.ts exists and is adapted
 *    (see e2e/fixtures/global-setup.ts.example)
 * ─────────────────────────────────────────────────────────────────────────
 */

test.describe('Login and authenticated session', () => {
  test('authenticated user reaches a protected route without a bounce', async ({ page }) => {
    // [TODO] Replace '/dashboard' with your app's main protected route.
    await page.goto('/dashboard')

    // Assert the final URL to detect a bounce. Use toHaveURL with a regex that
    // matches the protected route — if the middleware redirects to the landing, it fails.
    await expect(page).toHaveURL(/\/dashboard/)
    await expect(page.locator('body')).not.toBeEmpty()
  })

  test('navigation between authenticated routes preserves the session', async ({ page }) => {
    // [TODO] List 2-3 protected routes of your app to cover navigation.
    await page.goto('/dashboard')
    await expect(page).toHaveURL(/\/dashboard/)
    // Add more routes as you implement them:
    // await page.goto('/profile')
    // await expect(page).toHaveURL(/\/profile/)
  })
})
