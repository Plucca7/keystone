import { chromium, type FullConfig } from '@playwright/test'
import { mkdirSync } from 'node:fs'
import path from 'node:path'

/**
 * Global setup — logs in once before the whole suite and saves the storage state.
 *
 * Why: logging in through the UI on every test is expensive (2-5s × N tests) and
 * flaky (every time the login UI changes, the suite breaks). Reusing the storage
 * state solves both.
 *
 * Specs in critical/ use this session via use.storageState in playwright.config.
 * Specs in smoke/ ignore it (empty cookies).
 *
 * Credentials come from env vars (E2E_USER_EMAIL / E2E_USER_PASSWORD).
 * In CI, configure them in GitHub Secrets. Locally, in .env.local.
 *
 * ─────────────────────────────────────────────────────────────────────────
 * HOW TO ADAPT IT FOR YOUR PROJECT:
 *
 * 1. Rename this file: global-setup.ts.example → global-setup.ts
 * 2. Adjust the selectors between the [TODO] markers below to match your
 *    app's login UI (route path, input selectors, button).
 * 3. Adjust the waitForURL to your app's post-login pattern (/dashboard, /home, etc.)
 *
 * Examples of common patterns:
 *
 *   // Login on a dedicated /login route:
 *   await page.goto(`${baseURL}/login`)
 *   await page.getByLabel(/e-?mail/i).fill(email)
 *
 *   // Login in a modal opened via a CTA on the landing page:
 *   await page.goto(`${baseURL}/`)
 *   await page.getByRole('button', { name: /sign in|log in/i }).click()
 *
 *   // Inputs with a semantic label (htmlFor):
 *   await page.getByLabel(/e-?mail/i).fill(email)
 *
 *   // Inputs without htmlFor — use the placeholder:
 *   await page.getByPlaceholder('you@example.com').fill(email)
 * ─────────────────────────────────────────────────────────────────────────
 */
export default async function globalSetup(_config: FullConfig) {
  const email = process.env.E2E_USER_EMAIL
  const password = process.env.E2E_USER_PASSWORD
  const baseURL = process.env.E2E_BASE_URL || 'http://localhost:3000'

  // Without credentials: smoke tests still work (they do not depend on auth).
  // Critical tests will fail with a clear "missing env var" message.
  if (!email || !password) {
    console.warn(
      '[e2e] E2E_USER_EMAIL / E2E_USER_PASSWORD are not configured. ' +
        'Specs in critical/ will skip or fail. Configure them in .env.local or GitHub Secrets.',
    )
    return
  }

  const storageDir = path.join(__dirname, '..', '.auth')
  mkdirSync(storageDir, { recursive: true })
  const storagePath = path.join(storageDir, 'storage-state.json')

  const browser = await chromium.launch()
  const context = await browser.newContext()
  const page = await context.newPage()

  // [TODO] Adjust the login flow for your project
  await page.goto(`${baseURL}/login`)
  await page.getByLabel(/e-?mail/i).fill(email)
  await page.getByLabel(/password/i).fill(password)
  await page.getByRole('button', { name: /sign in|log in/i }).click()

  // [TODO] Adjust your app's post-login URL pattern
  await page.waitForURL(/\/(dashboard|home|app)/, { timeout: 30_000 })

  await context.storageState({ path: storagePath })
  await browser.close()
}
