{
  "name": "api-service",
  "version": "0.1.0",
  "private": true,
  "description": "Service (API) — TypeScript/Node",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "db:migrate": "sh scripts/db-migrate.sh",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.22.0",
  "dependencies": {
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^9.0.0",
    "@repo/commitlint-config": "file:./config/commitlint-config",
    "@repo/eslint-config": "file:./config/eslint-config",
    "@repo/prettier-config": "file:./config/prettier-config",
    "@repo/tsconfig": "file:./config/tsconfig",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "pg": "^8.13.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "prettier": "@repo/prettier-config",
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "vite": ">=6.4.3 <7",
      "esbuild": ">=0.28.1",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "js-yaml@>=4.0.0 <=4.1.1": ">=4.2.0"
    }
  }
}
